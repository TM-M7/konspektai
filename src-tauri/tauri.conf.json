{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "konspektai",
  "version": "0.8.0",
  "identifier": "com.konspektai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "konspektai",
        "width": 1420,
        "height": 940,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Local-first study copilot desktop shell",
    "category": "Education"
  }
}
